vrrp_instance R {
    interface {{ keepalived_lan_interface }}
    state BACKUP
    virtual_router_id {{ keepalived_router_id }}
    priority {{ 100 + (groups['gateways'] | length) - (groups['gateways'].index(inventory_hostname)) }}
    advert_int 1
    nopreempt
    unicast_src_ip {{ hostvars[inventory_hostname]['ansible_facts'][keepalived_lan_interface]['ipv4']['address'] }}
    unicast_peer {
{% for host in groups['gateways'] if host != inventory_hostname %}
        {{ hostvars[host]['ansible_facts'][keepalived_lan_interface]['ipv4']['address'] }}
{% endfor %}
    }
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ keepalived_wan_ip }} dev {{ keepalived_wan_interface }}
        {{ keepalived_lan_ip }} dev {{ keepalived_lan_interface }}
    }
}
